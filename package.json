{
  "name": "sipmon",
  "version": "0.2.1",
  "description": "Terminal usage monitor and account switcher for AI providers",
  "license": "MIT",
  "type": "module",
  "bin": {
    "sipmon": "bin/sipmon.js"
  },
  "files": [
    "dist/*.js",
    "dist/providers/*.js",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "tui",
    "terminal",
    "openai",
    "codex",
    "usage",
    "monitor"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/liamvinberg/sipmon.git"
  },
  "homepage": "https://github.com/liamvinberg/sipmon",
  "bugs": {
    "url": "https://github.com/liamvinberg/sipmon/issues"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "start": "bun run dist/cli.js",
    "build": "bunx tsc --outDir dist",
    "build:binary": "bash ./scripts/build-binary.sh",
    "build:artifact": "bash ./scripts/build-release-artifact.sh",
    "check": "bunx tsc --noEmit",
    "version:bump": "node ./scripts/bump-version.mjs",
    "version:patch": "node ./scripts/bump-version.mjs patch",
    "version:minor": "node ./scripts/bump-version.mjs minor",
    "version:major": "node ./scripts/bump-version.mjs major",
    "prepack": "bun run build",
    "pack:dry": "npm pack --dry-run",
    "release:prep": "bun run check && bun run build && bun run build:artifact && npm pack --dry-run"
  },
  "dependencies": {
    "@opentui/core": "^0.1.84",
    "@opentui/react": "^0.1.84",
    "react": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "typescript": "^5.9.0"
  }
}
